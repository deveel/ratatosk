<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="Deveel.Messaging.Abstractions">
      <HintPath>..\..\libs\Deveel.Messaging.Abstractions.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="Deveel.Messaging.Connector.Abstractions">
      <HintPath>..\..\libs\Deveel.Messaging.Connector.Abstractions.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="Deveel.Messaging.Connectors">
      <HintPath>..\..\libs\Deveel.Messaging.Connectors.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="Deveel.Messaging">
      <HintPath>..\..\libs\Deveel.Messaging.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="Deveel.Messaging.Connector.Telegram">
      <HintPath>..\..\libs\Deveel.Messaging.Connector.Telegram.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <PackageReference Include="Spectre.Console" Version="0.49.1" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Cocona" Version="2.2.0" />
    <PackageReference Include="Deveel.Results" Version="1.2.1" />
    <PackageReference Include="Microsoft.Extensions.Http" Version="8.0.1" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console" Version="8.0.0" />
    <PackageReference Include="Microsoft.Extensions.Options" Version="8.0.2" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" Version="8.0.1" />
    <PackageReference Include="Telegram.Bot" Version="22.0.0" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\..\..\shared\SampleConfigurationStore.cs" Link="Support\SampleConfigurationStore.cs" />
    <Compile Include="..\..\..\shared\SampleConsolePrompts.cs" Link="Support\SampleConsolePrompts.cs" />
    <Compile Include="..\..\..\shared\SampleOutputHelper.cs" Link="Support\SampleOutputHelper.cs" />
  </ItemGroup>

  <Target Name="EnsureConnectorLibs" BeforeTargets="ResolveReferences">
    <Error Condition="!Exists('..\..\libs\Deveel.Messaging.dll') or !Exists('..\..\libs\Deveel.Messaging.Connectors.dll') or !Exists('..\..\libs\Deveel.Messaging.Connector.Telegram.dll')" Text="Run ./build-libs.sh from the sample root to populate libs/ before building this sample." />
  </Target>
</Project>
